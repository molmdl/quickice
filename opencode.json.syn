{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "synthetic/syn:small:text",
  "agent": {
    "gsd-planner": { "model": "synthetic/syn:large:text" },
    "gsd-plan-checker": { "model": "synthetic/syn:large:text" },
    "gsd-phase-researcher": { "model": "synthetic/syn:large:text" },
    "gsd-roadmapper": { "model": "synthetic/syn:large:text" },
    "gsd-project-researcher": { "model": "synthetic/syn:large:text" },
    "gsd-research-synthesizer": { "model": "synthetic/syn:large:text" },
    "gsd-codebase-mapper": { "model": "synthetic/syn:large:text" },
    "gsd-executor": { "model": "synthetic/syn:large:text" },
    "gsd-debugger": { "model": "synthetic/syn:large:text" },
    "gsd-verifier": { "model": "synthetic/syn:large:text" },
    "gsd-integration-checker": { "model": "synthetic/syn:large:text" },
    "gsd-set-profile": { "model": "synthetic/syn:small:text" },
    "gsd-settings": { "model": "synthetic/syn:small:text" },
    "gsd-set-model": { "model": "synthetic/syn:small:text" },
    "cp-gsd-planner": { "model": "synthetic/syn:large:text" },
    "cp-gsd-plan-checker": { "model": "synthetic/syn:large:text" },
    "cp-gsd-phase-researcher": { "model": "synthetic/syn:large:text" },
    "cp-gsd-roadmapper": { "model": "synthetic/syn:large:text" },
    "cp-gsd-project-researcher": { "model": "synthetic/syn:large:text" },
    "cp-gsd-research-synthesizer": { "model": "synthetic/syn:large:text" },
    "cp-gsd-codebase-mapper": { "model": "synthetic/syn:large:text" },
    "cp-gsd-executor": { "model": "synthetic/syn:large:text" },
    "cp-gsd-debugger": { "model": "synthetic/syn:large:text" },
    "cp-gsd-verifier": { "model": "synthetic/syn:large:text" },
    "cp-gsd-integration-checker": { "model": "synthetic/syn:large:text" },
    "cp-gsd-set-profile": { "model": "synthetic/syn:small:text" },
    "cp-gsd-settings": { "model": "synthetic/syn:small:text" },
    "cp-gsd-set-model": { "model": "synthetic/syn:small:text" }
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/.local/share/opencode/tool-output/*": "allow",
      "~/.local/share/opencode/plans/*": "allow",
      "~/.config/opencode/get-shit-done/**": "allow"
    },
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git push*": "ask",
      "git pull*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "git reset*": "ask",
      "git checkout*": "ask",
      "npm *": "ask",
      "rm *": "deny",
      "rg *": "deny",
      "pip *": "ask",
      "pip3 *": "ask",
      "apt *": "ask",
      "mv *": "ask",
      "conda *": "ask",
      "wget *": "ask",
      "curl *": "ask",
      "python *": "ask"
    },
    "edit": {
      "*": "ask"
    }
  }
}
